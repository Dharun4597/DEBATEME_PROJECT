# Get a key at https://console.anthropic.com/settings/keys
#
# WARNING: This key will be embedded in your browser bundle. Fine for local
# dev, but do NOT deploy this app publicly as-is — see the note at the top
# of src/api/claude.js for how to move this behind a backend.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
